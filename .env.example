# Server
PORT=4000

# MongoDB (Railway plugin or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/evento

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=30d

# Groq AI (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Free OpenStreetMap services (defaults are public dev servers — rate limited)
# Photon is the primary geocoder (works from cloud/datacenter IPs; Nominatim 403s them)
PHOTON_URL=https://photon.komoot.io
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter
OSRM_URL=https://router.project-osrm.org
# Nominatim/Overpass require a descriptive UA per their usage policy
GEO_USER_AGENT=evento-app/1.0 (contact@example.com)
